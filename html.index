<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RG Clean – Higienização e Impermeabilização</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root {
  --g1: #0a3d12;
  --g2: #0d5c1a;
  --g3: #1a8a2a;
  --g4: #6abf2e;
  --g5: #96e63a;
  --white: #ffffff;
  --off: #f3f7f0;
  --text: #1a2e1a;
  --muted: #5a7a5a;
  --shadow: rgba(13,92,26,0.18);
  --r: 20px;
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Nunito', sans-serif;
  background: var(--white);
  color: var(--text);
  overflow-x: hidden;
}

/* ── SCROLLBAR ── */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--g1); }
::-webkit-scrollbar-thumb { background: var(--g4); border-radius: 3px; }

/* ── NAV ── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  background: rgba(10,61,18,0.95);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(150,230,58,0.12);
  height: 64px;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 5%;
  transition: background 0.3s;
}
.nav-brand {
  display: flex; align-items: center; gap: 10px;
  text-decoration: none;
}
.nav-brand img { height: 42px; display: block; }
.nav-brand-text {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.7rem; letter-spacing: 0.06em;
  color: var(--white); line-height: 1;
}
.nav-brand-text span { color: var(--g5); }
.nav-links { display: flex; align-items: center; gap: 6px; list-style: none; }
.nav-links li a {
  color: rgba(255,255,255,0.82); text-decoration: none;
  font-weight: 700; font-size: 0.82rem; letter-spacing: 0.06em;
  text-transform: uppercase; padding: 6px 12px; border-radius: 8px;
  transition: color 0.2s, background 0.2s;
}
.nav-links li a:hover { color: var(--g5); background: rgba(150,230,58,0.08); }
.nav-cta {
  background: linear-gradient(135deg, #1db954, #25D366) !important;
  color: #fff !important; padding: 8px 16px !important;
  border-radius: 50px !important;
  box-shadow: 0 0 16px rgba(37,211,102,0.35);
  display: inline-flex !important; align-items: center; gap: 6px;
  font-size: 0.8rem !important;
  transition: transform 0.2s, box-shadow 0.2s !important;
}
.nav-cta:hover { transform: scale(1.05); box-shadow: 0 0 24px rgba(37,211,102,0.55) !important; background: rgba(0,0,0,0) !important; }

/* hamburger */
.hamburger { display: none; cursor: pointer; padding: 6px; border: none; background: none; }
.hamburger span { display: block; width: 24px; height: 2px; background: #fff; border-radius: 2px; transition: 0.3s; }
.hamburger span + span { margin-top: 5px; }
.nav-mobile { display: none; }

/* ── HERO ── */
.hero {
  min-height: 100svh;
  background: linear-gradient(160deg, #061f09 0%, #0a3d12 30%, #0d5c1a 60%, #1a8a2a 100%);
  display: flex; align-items: center; justify-content: center;
  padding: 80px 5% 60px;
  position: relative;
  overflow: hidden;
  text-align: center;
}

/* noise grain overlay */
.hero::after {
  content: '';
  position: absolute; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events: none; z-index: 1; opacity: 0.5;
}

.hero-orb {
  position: absolute; border-radius: 50%; pointer-events: none;
  animation: orb-float 10s ease-in-out infinite;
}
.hero-orb-1 {
  width: 520px; height: 520px;
  background: radial-gradient(circle, rgba(150,230,58,0.12) 0%, transparent 70%);
  top: -160px; right: -120px; animation-delay: 0s;
}
.hero-orb-2 {
  width: 320px; height: 320px;
  background: radial-gradient(circle, rgba(26,138,42,0.25) 0%, transparent 70%);
  bottom: -60px; left: -80px; animation-delay: -4s;
}
.hero-orb-3 {
  width: 200px; height: 200px;
  background: radial-gradient(circle, rgba(150,230,58,0.1) 0%, transparent 70%);
  top: 40%; left: 10%; animation-delay: -7s;
}
@keyframes orb-float {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-24px) scale(1.04); }
}

/* grid lines decoration */
.hero-grid {
  position: absolute; inset: 0; pointer-events: none;
  background-image:
    linear-gradient(rgba(150,230,58,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(150,230,58,0.04) 1px, transparent 1px);
  background-size: 60px 60px;
}

.hero-content { position: relative; z-index: 2; max-width: 680px; margin: 0 auto; }
.hero-logo {
  height: 80px; width: auto; margin: 0 auto 28px;
  filter: drop-shadow(0 8px 32px rgba(0,0,0,0.4));
  animation: fade-down 0.9s cubic-bezier(0.22,1,0.36,1) both;
}
.hero-logo-text {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 3.8rem; line-height: 1; color: var(--white);
  letter-spacing: 0.06em; margin-bottom: 28px;
  animation: fade-down 0.9s cubic-bezier(0.22,1,0.36,1) both;
}
.hero-logo-text span { color: var(--g5); }
@keyframes fade-down { from { opacity: 0; transform: translateY(-24px); } to { opacity: 1; transform: translateY(0); } }

.hero h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(3rem, 10vw, 6rem);
  line-height: 0.95; letter-spacing: 0.01em; color: var(--white);
  animation: fade-up 0.9s 0.15s cubic-bezier(0.22,1,0.36,1) both;
}
.hero h1 em { color: var(--g5); font-style: normal; }
.hero-sub {
  color: rgba(255,255,255,0.75); font-size: clamp(0.95rem, 2.5vw, 1.15rem);
  font-weight: 600; line-height: 1.6; margin: 20px 0 36px;
  animation: fade-up 0.9s 0.28s cubic-bezier(0.22,1,0.36,1) both;
}
@keyframes fade-up { from { opacity: 0; transform: translateY(28px); } to { opacity: 1; transform: translateY(0); } }

.hero-btns {
  display: flex; gap: 14px; justify-content: center; flex-wrap: wrap;
  animation: fade-up 0.9s 0.4s cubic-bezier(0.22,1,0.36,1) both;
}
.btn-wpp {
  display: inline-flex; align-items: center; gap: 10px;
  background: linear-gradient(135deg, #1db954, #25D366);
  color: #fff; padding: 15px 28px; border-radius: 50px;
  font-weight: 800; font-size: 0.98rem; text-decoration: none;
  box-shadow: 0 6px 32px rgba(37,211,102,0.45);
  transition: transform 0.2s, box-shadow 0.2s;
  white-space: nowrap;
}
.btn-wpp:hover { transform: translateY(-3px) scale(1.03); box-shadow: 0 12px 40px rgba(37,211,102,0.6); }
.btn-outline {
  display: inline-flex; align-items: center; gap: 8px;
  border: 2px solid rgba(255,255,255,0.5); color: var(--white);
  padding: 13px 24px; border-radius: 50px;
  font-weight: 700; font-size: 0.95rem; text-decoration: none;
  transition: border-color 0.2s, background 0.2s;
  white-space: nowrap;
}
.btn-outline:hover { border-color: var(--g5); background: rgba(150,230,58,0.1); }

.hero-pills {
  display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;
  margin-top: 44px;
  animation: fade-up 0.9s 0.54s cubic-bezier(0.22,1,0.36,1) both;
}
.pill {
  display: flex; align-items: center; gap: 7px;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.16);
  backdrop-filter: blur(12px);
  padding: 8px 16px; border-radius: 50px;
  color: rgba(255,255,255,0.9); font-size: 0.82rem; font-weight: 700;
}
.pill-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--g5); flex-shrink: 0; }

/* scroll indicator */
.scroll-hint {
  position: absolute; bottom: 28px; left: 50%; transform: translateX(-50%);
  z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 6px;
  color: rgba(255,255,255,0.4); font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase;
  animation: fade-up 1s 1s both;
}
.scroll-hint::after {
  content: '';
  display: block; width: 1px; height: 36px;
  background: linear-gradient(to bottom, rgba(255,255,255,0.3), transparent);
  animation: line-drop 1.6s ease-in-out infinite;
}
@keyframes line-drop {
  0% { transform: scaleY(0); transform-origin: top; }
  50% { transform: scaleY(1); transform-origin: top; }
  51% { transform: scaleY(1); transform-origin: bottom; }
  100% { transform: scaleY(0); transform-origin: bottom; }
}

/* ── SECTION BASE ── */
section { padding: 88px 5%; }
.sec-eyebrow {
  display: inline-block;
  font-size: 0.72rem; font-weight: 900;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--g4); margin-bottom: 10px;
}
.sec-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(2.2rem, 5vw, 3.4rem);
  line-height: 1; color: var(--g1); margin-bottom: 14px;
}
.sec-sub {
  color: var(--muted); font-size: 1rem; font-weight: 600;
  line-height: 1.65; max-width: 500px;
}
.center { text-align: center; }
.center .sec-sub { margin: 0 auto; }

/* reveal on scroll */
.reveal { opacity: 0; transform: translateY(32px); transition: opacity 0.7s ease, transform 0.7s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }

/* ── SERVIÇOS ── */
.servicos { background: var(--off); }
.srv-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 22px; margin-top: 52px;
}
.srv-card {
  background: var(--white); border-radius: var(--r); padding: 32px 26px;
  box-shadow: 0 2px 20px rgba(13,92,26,0.07);
  border: 1px solid rgba(106,191,46,0.12);
  position: relative; overflow: hidden;
  transition: transform 0.3s cubic-bezier(0.22,1,0.36,1), box-shadow 0.3s;
}
.srv-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, var(--g3), var(--g5));
}
.srv-card::after {
  content: '';
  position: absolute; bottom: -60px; right: -60px;
  width: 160px; height: 160px; border-radius: 50%;
  background: radial-gradient(circle, rgba(150,230,58,0.07), transparent);
  transition: transform 0.4s;
}
.srv-card:hover { transform: translateY(-7px); box-shadow: 0 16px 40px rgba(13,92,26,0.13); }
.srv-card:hover::after { transform: scale(1.5); }
.srv-icon {
  width: 56px; height: 56px; border-radius: 14px;
  background: linear-gradient(135deg, var(--g2), var(--g4));
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 18px;
  box-shadow: 0 6px 20px var(--shadow);
}
.srv-icon svg { width: 26px; height: 26px; fill: var(--white); }
.srv-card h3 { font-size: 1.1rem; font-weight: 900; color: var(--g1); margin-bottom: 8px; }
.srv-card p { font-size: 0.9rem; color: var(--muted); line-height: 1.65; }

/* ── ANTES E DEPOIS ── */
.resultados { background: var(--white); }
.ad-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
  gap: 24px; margin-top: 52px;
}
.ad-card {
  border-radius: var(--r); overflow: hidden;
  box-shadow: 0 4px 28px rgba(13,92,26,0.1);
  transition: transform 0.3s cubic-bezier(0.22,1,0.36,1), box-shadow 0.3s;
  background: var(--g1);
  position: relative;
}
.ad-card:hover { transform: translateY(-6px) scale(1.01); box-shadow: 0 16px 48px rgba(13,92,26,0.18); }
.ad-card img {
  width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block;
  transition: transform 0.5s ease;
}
.ad-card:hover img { transform: scale(1.03); }
.ad-label {
  background: linear-gradient(90deg, var(--g1), var(--g2));
  padding: 12px 18px;
  display: flex; align-items: center; gap: 8px;
  border-top: 1px solid rgba(150,230,58,0.15);
}
.ad-label svg { width: 16px; height: 16px; fill: var(--g5); flex-shrink: 0; }
.ad-label span { color: var(--white); font-weight: 800; font-size: 0.82rem; letter-spacing: 0.05em; text-transform: uppercase; }

/* ── DIFERENCIAIS ── */
.diferenciais {
  background: linear-gradient(160deg, var(--g1) 0%, #0f7020 100%);
  position: relative; overflow: hidden;
}
.dif-bg-circle {
  position: absolute; border-radius: 50%; pointer-events: none;
}
.dif-bg-circle-1 {
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(150,230,58,0.07), transparent);
  top: -150px; right: -150px;
}
.dif-bg-circle-2 {
  width: 300px; height: 300px;
  background: radial-gradient(circle, rgba(26,138,42,0.2), transparent);
  bottom: -80px; left: -80px;
}
.diferenciais .sec-eyebrow { color: var(--g5); }
.diferenciais .sec-title { color: var(--white); }
.diferenciais .sec-sub { color: rgba(255,255,255,0.7); max-width: 100%; }
.dif-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
  gap: 20px; margin-top: 52px; position: relative; z-index: 1;
}
.dif-item {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 16px; padding: 26px 20px; text-align: center;
  transition: background 0.3s, transform 0.3s;
  cursor: default;
}
.dif-item:hover { background: rgba(255,255,255,0.11); transform: translateY(-4px); }
.dif-ico {
  width: 50px; height: 50px; border-radius: 50%;
  background: rgba(150,230,58,0.14);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 14px;
}
.dif-ico svg { width: 24px; height: 24px; fill: var(--g5); }
.dif-item h4 { color: var(--g5); font-weight: 900; font-size: 0.95rem; margin-bottom: 8px; }
.dif-item p { color: rgba(255,255,255,0.68); font-size: 0.86rem; line-height: 1.6; }

/* ── DEPOIMENTOS ── */
.depoimentos { background: var(--off); }
.dep-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
  gap: 22px; margin-top: 52px;
}
.dep-card {
  background: var(--white); border-radius: var(--r); padding: 28px;
  box-shadow: 0 2px 20px rgba(13,92,26,0.06);
  border-left: 4px solid var(--g4);
  position: relative; overflow: hidden;
  transition: transform 0.3s, box-shadow 0.3s;
}
.dep-card:hover { transform: translateY(-4px); box-shadow: 0 10px 32px rgba(13,92,26,0.1); }
.dep-card::after {
  content: '"';
  position: absolute; top: -10px; right: 20px;
  font-size: 7rem; line-height: 1;
  color: rgba(106,191,46,0.08);
  font-family: Georgia, serif; pointer-events: none;
}
.stars { color: #f9c130; font-size: 0.9rem; letter-spacing: 3px; margin-bottom: 12px; }
.dep-card p { font-size: 0.92rem; color: #444; line-height: 1.7; font-style: italic; margin-bottom: 16px; }
.dep-author { font-weight: 900; font-size: 0.85rem; color: var(--g1); }

/* ── CTA FINAL ── */
.cta-final {
  background: linear-gradient(160deg, #061f09 0%, var(--g1) 40%, var(--g2) 100%);
  text-align: center; padding: 100px 5%;
  position: relative; overflow: hidden;
}
.cta-final::before {
  content: '';
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse at 50% 0%, rgba(150,230,58,0.1) 0%, transparent 60%);
  pointer-events: none;
}
.cta-final h2 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(2.4rem, 7vw, 4.5rem);
  color: var(--white); line-height: 1; margin-bottom: 16px; position: relative; z-index: 1;
}
.cta-final h2 em { color: var(--g5); font-style: normal; }
.cta-final p {
  color: rgba(255,255,255,0.75); font-size: 1.05rem;
  font-weight: 600; margin-bottom: 40px; position: relative; z-index: 1;
}
.cta-phone {
  display: inline-flex; align-items: center; gap: 10px;
  color: var(--g5); font-size: 1.6rem; font-weight: 900;
  text-decoration: none; margin-bottom: 32px;
  position: relative; z-index: 1;
  transition: transform 0.2s;
}
.cta-phone:hover { transform: scale(1.04); }
.cta-phone svg { width: 28px; height: 28px; fill: var(--g5); }

/* ── FOOTER ── */
footer {
  background: #060e07; padding: 36px 5%; text-align: center;
  border-top: 1px solid rgba(150,230,58,0.08);
}
.footer-logo {
  height: 48px; margin-bottom: 14px; opacity: 0.85;
}
.footer-logo-text {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 2rem; color: var(--white); letter-spacing: 0.06em;
  margin-bottom: 14px;
}
.footer-logo-text span { color: var(--g5); }
footer p { color: rgba(255,255,255,0.38); font-size: 0.8rem; line-height: 1.8; }
footer a { color: var(--g4); text-decoration: none; }

/* ── FLOATING WPP ── */
.wpp-float {
  position: fixed; bottom: 22px; right: 22px; z-index: 999;
  width: 60px; height: 60px; border-radius: 50%;
  background: linear-gradient(135deg, #1db954, #25D366);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 6px 32px rgba(37,211,102,0.5);
  text-decoration: none;
  animation: wpp-pulse 2.5s ease infinite;
  transition: transform 0.2s;
}
.wpp-float:hover { transform: scale(1.12); }
.wpp-float svg { width: 30px; height: 30px; fill: var(--white); }
@keyframes wpp-pulse {
  0%, 100% { box-shadow: 0 6px 32px rgba(37,211,102,0.5); }
  50% { box-shadow: 0 6px 48px rgba(37,211,102,0.8); }
}

/* ── MOBILE NAV ── */
@media (max-width: 720px) {
  .nav-links { display: none !important; }
  .hamburger { display: flex; flex-direction: column; }
  .nav-mobile {
    position: fixed; top: 64px; left: 0; right: 0; z-index: 199;
    background: rgba(8,30,10,0.98);
    backdrop-filter: blur(16px);
    padding: 20px 5% 28px;
    border-bottom: 1px solid rgba(150,230,58,0.1);
    transform: translateY(-110%);
    transition: transform 0.35s cubic-bezier(0.22,1,0.36,1);
  }
  .nav-mobile.open { transform: translateY(0); display: block; }
  .nav-mobile a {
    display: block; color: rgba(255,255,255,0.85); text-decoration: none;
    font-weight: 700; font-size: 1.1rem; padding: 14px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: color 0.2s;
  }
  .nav-mobile a:last-child { border-bottom: none; }
  .nav-mobile a:hover { color: var(--g5); }
  .nav-mobile .mob-cta {
    margin-top: 16px;
    background: linear-gradient(135deg, #1db954, #25D366);
    color: #fff !important; border-radius: 50px;
    text-align: center; padding: 14px !important;
    font-size: 1rem !important;
  }
}

/* ── RESPONSIVE ── */
@media (max-width: 720px) {
  nav { padding: 0 4%; }
  section { padding: 64px 4%; }
  .hero { padding: 76px 4% 56px; text-align: center; }
  .hero-logo { height: 62px; }
  .hero-pills { gap: 8px; }
  .pill { padding: 7px 12px; font-size: 0.76rem; }
  .srv-grid { grid-template-columns: 1fr 1fr; gap: 14px; }
  .srv-card { padding: 22px 16px; }
  .srv-icon { width: 46px; height: 46px; }
  .srv-icon svg { width: 22px; height: 22px; }
  .srv-card h3 { font-size: 0.95rem; }
  .srv-card p { font-size: 0.82rem; }
  .ad-grid { grid-template-columns: 1fr; }
  .dif-grid { grid-template-columns: 1fr 1fr; gap: 14px; }
  .dif-item { padding: 20px 14px; }
  .dep-grid { grid-template-columns: 1fr; }
  .cta-phone { font-size: 1.25rem; }
  .scroll-hint { display: none; }
  .wpp-float { width: 54px; height: 54px; bottom: 16px; right: 16px; }
  .wpp-float svg { width: 26px; height: 26px; }
}
@media (max-width: 420px) {
  .srv-grid { grid-template-columns: 1fr; }
  .dif-grid { grid-template-columns: 1fr 1fr; }
  .hero h1 { font-size: 3rem; }
}
</style>
</head>
<body>

<!-- SVG SPRITE -->
<svg xmlns="http://www.w3.org/2000/svg" style="display:none">
  <symbol id="ico-wpp" viewBox="0 0 24 24">
